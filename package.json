{
    "name": "@igorskyflyer/editorconfig",
    "version": "1.0.0",
    "description": "✍🏼 Opinionated EditorConfig for consistent code style across editors and IDEs. 🐭",
    "sideEffects": false,
    "engines": {
        "node": ">=24.0"
    },
    "type": "module",
    "bin": {
        "editorconfig": "./bin/index.js"
    },
    "files": [
        ".editorconfig",
        "bin/**/*.js"
    ],
    "scripts": {
        "build": "tsc",
        "pub": "git push origin main --tags"
    },
    "keywords": [
        "editorconfig",
        "editor",
        "tabs",
        "spaces",
        "format",
        "formatting",
        "code",
        "spacing",
        "dx",
        "igor dimitrijević",
        "igorskyflyer"
    ],
    "license": "MIT",
    "author": "Igor Dimitrijević <support@igorskyflyer.me> (https://github.com/igorskyflyer)",
    "funding": "https://ko-fi.com/igorskyflyer",
    "homepage": "https://github.com/igorskyflyer/npm-editorconfig",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/igorskyflyer/npm-editorconfig.git"
    },
    "bugs": {
        "url": "https://github.com/igorskyflyer/npm-editorconfig/issues"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@igorskyflyer/biome-config": "^2.2.0",
        "@igorskyflyer/tsconfig": "^1.0.2",
        "@types/node": "^24.12.0",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.32.1"
}
